{
  "name": "personal-persistence-ai-memory",
  "version": "1.0.0",
  "description": "Persistent memory layer for AI agents with extended session tracking, docs indexing, and skills detection",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "persistence-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/db && cp src/db/schema.sql dist/db/schema.sql",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest",
    "migrate": "tsx src/db/migrate.ts"
  },
  "keywords": ["ai", "memory", "persistence", "mcp", "agent", "sqlite", "fts5"],
  "license": "MIT",
  "author": "nunezlagos",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}